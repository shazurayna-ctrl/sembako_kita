# ============================================
# SEMBAKOKITA.PRO — .gitignore
# ============================================

# ============================================
# NODE.JS
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# ENVIRONMENT
# ============================================
.env
.env.local
.env.*.local
*.env

# ============================================
# BUILD OUTPUT
# ============================================
dist/
build/
out/
target/
*.apk
*.exe
*.dmg
*.msi
*.deb
*.app
*.ipa

# ============================================
# TAURI
# ============================================
src-tauri/target/
src-tauri/gen/
src-tauri/*.rs.bk
*.rs.bk

# ============================================
# IDE & EDITOR
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.vscode/
*.sublime-*

# ============================================
# OS GENERATED
# ============================================
Thumbs.db
ehthumbs.db
Desktop.ini
*.tmp
*.temp

# ============================================
# LOGS
# ============================================
logs/
*.log
*.log.*

# ============================================
# DATABASE
# ============================================
*.db
*.sqlite
*.sqlite3
*.db-journal

# ============================================
# BACKUP
# ============================================
*.bak
*.backup
*.old

# ============================================
# TEST
# ============================================
coverage/
.nyc_output/
test-results/

# ============================================
# MISC
# ============================================
*.zip
*.tar.gz
*.rar
*.7z
.DS_Store
.cache/
.temp/
tmp/

# ============================================
# SECURITY
# ============================================
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.csr

# ============================================
# GENERATED FILES
# ============================================
*.generated.*
*.min.*
*.bundle.*
